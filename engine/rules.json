{
  "version": "1.0.0",
  "engine": "TEOS Sentinel",
  "total_rules": 32,
  "categories": [
    "command_injection",
    "prompt_injection",
    "data_exfiltration",
    "privilege_escalation",
    "tool_misuse",
    "execution_abuse"
  ],
  "rules": [

    {
      "id": "R001",
      "name": "DESTRUCTIVE_SHELL_RM_ROOT",
      "category": "command_injection",
      "pattern": "rm -rf /",
      "match_type": "string",
      "severity": 100,
      "weight": 1.0,
      "action": "block",
      "tags": ["filesystem", "critical"]
    },
    {
      "id": "R002",
      "name": "DESTRUCTIVE_WILDCARD_DELETE",
      "category": "command_injection",
      "pattern": "rm -rf *",
      "match_type": "string",
      "severity": 95,
      "weight": 1.0,
      "action": "block",
      "tags": ["filesystem"]
    },
    {
      "id": "R003",
      "name": "FORMAT_FILESYSTEM",
      "category": "command_injection",
      "pattern": "mkfs",
      "match_type": "keyword",
      "severity": 90,
      "weight": 0.9,
      "action": "block",
      "tags": ["filesystem"]
    },
    {
      "id": "R004",
      "name": "FORK_BOMB",
      "category": "execution_abuse",
      "pattern": ":(){ :|:& };:",
      "match_type": "string",
      "severity": 100,
      "weight": 1.0,
      "action": "block",
      "tags": ["dos"]
    },

    {
