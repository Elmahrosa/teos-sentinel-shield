APP_NAME=safe-ingestion-engine
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database
# Use PostgreSQL in production. SQLite is acceptable only for local development.
DATABASE_URL=sqlite:///./data/jobs.db
# DATABASE_URL=postgresql://user:password@host:5432/safe_ingestion

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Secrets — rotate before production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PII_SALT=replace-with-64-char-hex-secret
API_KEY_SALT=replace-with-64-char-hex-secret
GAS_WEBHOOK_SECRET=replace-with-64-char-hex-secret

# Minimum 12 chars
DASHBOARD_ADMIN_PASSWORD=replace-with-strong-password

# Legacy fallback only. Leave empty list when using the Redis billing bridge.
API_KEY_HASHES_JSON=[]

REQUEST_TIMEOUT_SECONDS=10
MAX_RESPONSE_BYTES=5242880
ROBOTS_ERROR_MODE=deny
ALLOW_REDIRECTS=false
RATE_LIMIT_PER_MINUTE=10
CORS_ORIGINS_JSON=["https://safe.teosegypt.com"]
